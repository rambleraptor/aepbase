---
const features = [
  {
    title: 'Dynamic resource definitions',
    body: 'POST a schema, endpoints go live instantly.',
    icon: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>'
  },
  {
    title: 'Full CRUD out of the box',
    body: 'Create, read, update, delete, list with pagination.',
    icon: '<path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h10"/>'
  },
  {
    title: 'Always-fresh OpenAPI spec',
    body: 'Served at /openapi.json and never stale.',
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>'
  },
  {
    title: 'Nested resources',
    body: 'Parent-child paths with full referential integrity.',
    icon: '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>'
  },
  {
    title: 'Custom methods',
    body: 'Add domain actions like POST /books/{id}:archive.',
    icon: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>'
  },
  {
    title: 'SQLite with zero config',
    body: 'Persisted in WAL mode with no setup needed.',
    icon: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>'
  },
  {
    title: 'Embeddable as a library',
    body: 'Run standalone or embed in your Go app.',
    icon: '<line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>'
  },
  {
    title: 'Built-in authentication',
    body: 'Opt-in Bearer tokens with hashing and scoping.',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>'
  },
];
---

<section class="features" id="features">
  <div class="features-inner">
    <div class="section-header">
      <h2>Everything you need to ship an API.</h2>
      <p>Every feature follows the <a href="https://aep.dev">AEP standard</a>.</p>
    </div>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature-item">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon}></svg>
          </div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
