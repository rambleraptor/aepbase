---
---

<section class="cta">
  <div class="cta-inner">
    <h2>Start shipping your APIs.</h2>
    <p>aepbase is open source and free to use. One binary, zero config, a real API in the time it takes to brew coffee.</p>
    <div class="cta-actions">
      <a href="https://github.com/rambleraptor/aepbase" class="btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        View on GitHub
      </a>
      <a href="https://aep.dev" class="btn btn-secondary">Learn about AEP</a>
    </div>
    <div class="cta-install">
      <span class="t-prompt">$</span>
      <span>go install github.com/rambleraptor/aepbase@latest</span>
      <button id="cta-copy" title="Copy" type="button">
        <svg id="cta-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  function initCta() {
    const copyBtn = document.getElementById('cta-copy');
    if (!copyBtn) return;
    const checkSvg = '<svg id="cta-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
    const copySvg = '<svg id="cta-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('go install github.com/rambleraptor/aepbase@latest');
        const icon = document.getElementById('cta-copy-icon');
        if (icon) icon.outerHTML = checkSvg;
        setTimeout(() => {
          const el = document.getElementById('cta-copy-icon');
          if (el) el.outerHTML = copySvg;
        }, 1500);
      } catch {}
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCta);
  } else {
    initCta();
  }
</script>
